{
  "name": "lycea-backend",
  "version": "1.0.0",
  "description": "Бэкенд школьной социальной сети Лицей",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:migrate": "psql -U $DB_USER -d $DB_NAME -f db/migrations.sql",
    "db:create": "psql -U postgres -c \"CREATE DATABASE lycea;\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.5"
  }
}